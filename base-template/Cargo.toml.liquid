[package]
name = "{{ project-name }}"
version = "0.1.0"
edition = "2024"
publish = false

# `cargo furiosa-opt` sets `--cfg backend="..."`. Declare the known values so the
# bare `cargo build` / `cargo check` paths don't emit unexpected-cfg warnings.
[lints.rust]
unexpected_cfgs = { level = "warn", check-cfg = ['cfg(backend, values("simulation", "emulation", "npu", "typecheck"))'] }

[lib]
path = "src/lib.rs"

[[bin]]
name = "constant_add"
path = "src/constant_add.rs"

[[bin]]
name = "elementwise_mul"
path = "src/elementwise_mul.rs"

[[bin]]
name = "dot_product"
path = "src/dot_product.rs"

[[bin]]
name = "gemv"
path = "src/gemv.rs"

[[bin]]
name = "gemm"
path = "src/gemm.rs"

[dependencies]
furiosa-opt-std = "0.2"
rand = "0.9"
tokio = { version = "1.29", features = ["rt", "rt-multi-thread", "sync", "macros"] }
